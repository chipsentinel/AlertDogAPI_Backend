{
  "name": "alertdogapi_backend",
  "scripts": {
    "start": "node src/app.js --config config.local.yaml --host 0.0.0.0 --port 3000",
    "dev": "nodemon src/app.js -- --config config.local.yaml --host 0.0.0.0 --port 3000",
    "test:api": "pwsh -ExecutionPolicy Bypass -File tests/integration/api-smoke-tests.ps1",
    "test:api:usuarios": "pwsh -ExecutionPolicy Bypass -File tests/integration/api-usuarios-crud-tests.ps1",
    "test:api:flujo": "pwsh -ExecutionPolicy Bypass -File tests/integration/api-flujo-perros-citas-tests.ps1",
    "test:integration": "npm run test:api:all",
    "test:api:all": "npm run test:api && npm run test:api:usuarios && npm run test:api:flujo",
    "test:unit": "jest --runInBand"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "js-yaml": "^4.1.1",
    "knex": "^3.1.0",
    "mysql2": "^3.17.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.11"
  }
}
